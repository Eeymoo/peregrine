{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Peregrine",
  "version": "0.1.8-alpha.1",
  "identifier": "com.eeymoo.peregrine",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Eeymoo/peregrine/releases/latest/download/stable.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGRDMyRTkxNjFBREVDMTQKUldRVTdLMWhrUzdUdndXQmZSSWFCUnowYnhQWHd4MTJjdjNjaUIvNWpOQkVzTjNKWmtqVWR5eDgK"
    }
  }
}
