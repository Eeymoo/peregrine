{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "default",
  "description": "Default capabilities for Peregrine settings window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:tray:default",
    "dialog:default",
    "dialog:allow-open"
  ]
}
